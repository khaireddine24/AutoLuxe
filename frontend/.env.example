# Copy to `.env` and adjust for your deployment.

# --- Backend (Django) ---
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS for the React frontend (must match the browser origin you serve frontend from)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000/

# SSLCommerz credentials (keep secret)
SSL_STORE_ID=replace-me
SSL_API_KEY=replace-me

# --- Database (Postgres) ---
USE_POSTGRES=true
POSTGRES_DB=autoluxe
POSTGRES_USER=autoluxe
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Ports exposed on the host machine ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Frontend build arg (CRA) ---
# CRA bakes this into the compiled frontend bundle at build time.
REACT_APP_API_BASE_URL=http://localhost:8000/
